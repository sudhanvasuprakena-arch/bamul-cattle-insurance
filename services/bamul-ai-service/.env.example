# BAMUL AI Service — Environment Variables
APP_NAME=BAMUL AI Service
APP_ENV=development
DEBUG=true

INTERNAL_TOKEN=CHANGE_ME_IN_PRODUCTION

FAISS_INDEX_PATH=/tmp/bamul_faiss.index
FAISS_FLAT_THRESHOLD=10000
FAISS_NLIST=100

MODEL_PATH=models/muzzle_model.pt
MODEL_VERSION=v1.0.0
EMBEDDING_DIM=512

AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=bamul-dev-faiss

MATCH_HIGH_CONFIDENCE_THRESHOLD=0.95
MATCH_MEDIUM_CONFIDENCE_THRESHOLD=0.80
MATCH_SLA_SECONDS=3.0
