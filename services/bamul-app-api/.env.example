# BAMUL App API — Environment Variables
# Copy to .env and fill in values for local development.
# Staging/Production: values loaded from AWS Secrets Manager.

APP_NAME=BAMUL App API
APP_ENV=development
DEBUG=true

# PostgreSQL (local dev via docker-compose)
DATABASE_URL=postgresql+asyncpg://bamul:bamul_dev_secret@localhost:5432/bamul_dev

# Redis (local dev via docker-compose)
REDIS_URL=redis://localhost:6379

# JWT — CHANGE THIS in all non-development environments
JWT_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# AI Service (internal VPC ALB in staging/production)
AI_SERVICE_BASE_URL=http://localhost:8001
AI_SERVICE_INTERNAL_TOKEN=CHANGE_ME_IN_PRODUCTION

# AWS (ap-south-1 — DPDP Act mandatory region)
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=bamul-dev-photos
AWS_SQS_EMBEDDING_QUEUE_URL=
AWS_SQS_MATCH_QUEUE_URL=

# UIDAI AUA eKYC (obtain AUA licence before Sprint 2)
UIDAI_AUA_CODE=
UIDAI_AUA_LICENCE_KEY=

# WhatsApp Business API
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=

# SMS Gateway
SMS_GATEWAY_API_KEY=

# Firebase FCM
FCM_SERVER_KEY=
