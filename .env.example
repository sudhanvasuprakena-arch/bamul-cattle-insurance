# Root .env.example — used by docker-compose.yml
# Copy to .env and fill in local development values.
# Service-specific vars in services/{name}/.env.example

# App API
APP_ENV=development
DEBUG=true
JWT_SECRET_KEY=CHANGE_ME_FOR_LOCAL_DEV_ONLY
AI_SERVICE_INTERNAL_TOKEN=CHANGE_ME_FOR_LOCAL_DEV_ONLY

# AWS (not needed for local dev docker-compose — services use localhost mocks)
AWS_REGION=ap-south-1
